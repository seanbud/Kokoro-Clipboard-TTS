{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for Kokoro Clipboard TTS",
  "windows": ["reader", "settings", "tutorial", "splash"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-set-position",
    "core:window:allow-set-focus",
    "core:window:allow-set-size",
    "core:window:allow-start-dragging",
    "opener:default",
    "opener:allow-open-path",
    "opener:allow-reveal-item-in-dir",
    "global-shortcut:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-is-registered",
    "updater:default",
    "store:default",
    "dialog:default",
    "dialog:allow-message",
    "dialog:allow-ask",
    "clipboard-manager:default",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "shell:default",
    "shell:allow-execute",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "python", "cmd": "python", "args": true },
        { "name": "kokoro-sidecar", "cmd": "binaries/kokoro", "sidecar": true },
        { "name": "venv-python-win", "cmd": ".sidecar-venv/Scripts/python.exe", "args": true },
        { "name": "venv-python-unix", "cmd": ".sidecar-venv/bin/python", "args": true }
      ]
    }
  ]
}
