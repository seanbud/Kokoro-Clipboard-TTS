{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kokoro-clipboard-tts",
  "version": "0.5.7",
  "identifier": "com.kokoro.clipboard-tts",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "reader",
        "title": "Reader",
        "url": "/",
        "width": 320,
        "height": 140,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true
      },
      {
        "label": "settings",
        "title": "Kokoro TTS — Settings",
        "url": "/",
        "width": 480,
        "height": 600,
        "visible": false,
        "resizable": false,
        "center": true
      },
      {
        "label": "tutorial",
        "title": "Welcome to Kokoro TTS",
        "url": "/",
        "width": 620,
        "height": 660,
        "visible": false,
        "resizable": false,
        "center": true,
        "decorations": false,
        "transparent": true,
        "shadow": false
      },
      {
        "label": "splash",
        "title": "Kokoro TTS",
        "url": "/",
        "width": 500,
        "height": 400,
        "visible": true,
        "resizable": false,
        "center": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/kokoro"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/icon.ico",
        "installerHooks": "nsis/hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "YOUR_UPDATER_PUBLIC_KEY_HERE",
      "endpoints": [
        "https://github.com/seanbud/Kokoro-Clipboard-TTS/releases/latest/download/latest.json"
      ]
    }
  }
}
